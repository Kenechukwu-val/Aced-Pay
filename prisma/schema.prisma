generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "sqlite"
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique  // acme.aced-pay.app
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members      TenantMember[]
  subscriptions   Subscription[]
}


model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  password  String?
  provider  String?  // 'email' | 'google' | 'github'
  providerId String? // OAuth subject ID
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships TenantMember[]
}

model TenantMember {
  id       String @id @default(uuid())
  userId   String
  tenantId String
  role     String @default("member") // 'owner' | 'admin' | 'member'
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])  // prevent duplicate memberships
}

model Plan {
  id          String   @id @default(uuid())
  name        String   @unique
  price       Int      // in cents
  interval    String   // 'month' | 'year'
  trialDays   Int      @default(14)
  features    String?  // JSON string for feature flags
  paystackPlanCode String? 
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subscriptions Subscription[]
}

model Subscription {
  id        String   @id @default(uuid())
  tenantId  String
  planId    String
  
  // Lifecycle
  status    String   @default("trialing") 
  // trialing | active | past_due | canceled | expired
  
  // Billing periods
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  trialEndDate       DateTime?
  
  // Cancellation
  canceledAt         DateTime?
  cancelAtPeriodEnd  Boolean   @default(false)
  
  // Grace period (in days)
  gracePeriodDays    Int       @default(7)
  
  // External references
  externalId         String?
  externalCustomerId String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  plan      Plan      @relation(fields: [planId], references: [id])
  payments  Payment[]
}


model Payment {
  id              String   @id @default(uuid())
  subscriptionId  String
  amount          Int
  currency        String   @default("USD")
  status          String   @default("pending") // pending | succeeded | failed
  paymentMethod   String?
  transactionId   String?
  paidAt          DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  subscription Subscription @relation(fields: [subscriptionId], references: [id])
}
